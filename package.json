{
	"name": "client",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "wrangler types --check && vite build",
		"preview": "wrangler pages dev .svelte-kit/cloudflare --port 4173",
		"prepare": "svelte-kit sync || echo ''",
		"check": "wrangler types --check && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"gen": "wrangler types"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/dom-speech-recognition": "^0.0.11",
		"@types/node": "^24",
		"@unocss/extractor-svelte": "^66.7.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"openapi-typescript": "^7.13.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"unocss": "^66.7.0",
		"vite": "^8.0.7",
		"wrangler": "^4.81.0"
	},
	"dependencies": {
		"@preact/signals": "^2.9.1",
		"@schedule-x/calendar": "^4.6.0",
		"@schedule-x/calendar-controls": "^4.6.0",
		"@schedule-x/current-time": "^4.6.0",
		"@schedule-x/events-service": "^4.6.0",
		"@schedule-x/svelte": "^3.0.0",
		"@schedule-x/theme-default": "^4.6.0",
		"@schedule-x/theme-shadcn": "^4.6.0",
		"openapi-fetch": "^0.17.0",
		"preact": "^10.29.2",
		"temporal-polyfill": "^0.3.2"
	}
}
