{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "enables the default permissions",
	"windows": ["main"],
	"permissions": [
		"core:default",
		{
			"identifier": "http:default",
			"allow": [{ "url": "https://aws.naroah.top/calendar/*" }]
		},
		"notification:default",
		"store:default",
		"stt:default"
	]
}
